# Reddit API credentials
# Create an app at https://www.reddit.com/prefs/apps/
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=AutoYoutuber/1.0

# Subreddits to scrape (comma-separated)
SUBREDDITS=funny,videos,Unexpected

# Scraping settings
TIME_FILTER=day
POST_LIMIT=20

# YouTube OAuth2
# Download client_secrets.json from Google Cloud Console
YOUTUBE_CLIENT_SECRETS_FILE=client_secrets.json
YOUTUBE_TOKEN_FILE=youtube_token.json

# Scheduling
VIDEOS_PER_DAY=3

# Paths
TEMP_DIR=temp
DB_PATH=processed_posts.db
LOG_FILE=auto_youtuber.log

# Video settings
MAX_DURATION_SECONDS=59
